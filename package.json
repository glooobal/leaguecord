{
	"name": "leaguecord",
	"version": "2.0.0",
	"description": "A discord bot integrated with Riot Games API. Created with discord.js and axios.",
	"license": "GPL-3.0",
	"main": "dist/index.js",
	"private": true,
	"scripts": {
		"build": "yarn prettier && yarn lint && tsc -p tsconfig.json",
		"start": "node dist/index.js | pino-pretty -c -t -l",
		"start:dev": "yarn build && nodemon . | pino-pretty -c -t -l",
		"start:prod": "yarn build && node dist/index.js | pino-pretty -c -t -l",
		"lint": "eslint src --ext .ts",
		"prettier": "prettier --write **/*.ts"
	},
	"author": {
		"name": "Jakub Górzny (glooobal)",
		"email": "jakubgorzny@icloud.com"
	},
	"contributors": [
		"adiq (https://github.com/adiq)"
	],
	"homepage": "https://github.com/glooobal/leaguecord",
	"repository": {
		"url": "https://github.com/glooobal/leaguecord",
		"type": "git"
	},
	"bugs": {
		"email": "jakubgorzny@icloud.com",
		"url": "https://github.com/glooobal/leaguecord/issues"
	},
	"keywords": [
		"discord-bot",
		"discord.js",
		"riot-games-api",
		"league-of-legends",
		"lol"
	],
	"dependencies": {
		"discord.js": "^14.7.1",
		"mongoose": "^6.9.1",
		"pino": "^8.10.0",
		"pino-pretty": "^9.2.0"
	},
	"devDependencies": {
		"@types/node": "^18.13.0",
		"@typescript-eslint/eslint-plugin": "^5.52.0",
		"@typescript-eslint/parser": "^5.52.0",
		"dotenv": "^16.0.3",
		"eslint": "^8.34.0",
		"eslint-plugin-check-file": "^1.3.1",
		"nodemon": "^2.0.20",
		"prettier": "^2.8.4",
		"typescript": "^4.9.5"
	}
}
